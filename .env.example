# ==============================================================================
# WPBot AI Platform — Environment Variables Example
# ==============================================================================
# Rename this file to .env and replace the placeholder values with your actual keys.
# NEVER commit your actual .env file to version control.
# ==============================================================================

# ── App Settings ──────────────────────────────────────────────────
APP_NAME="WPBot AI Platform"
APP_VERSION="1.0.0"
DEBUG=True

# ── Server ────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000

# ── Database ──────────────────────────────────────────────────────
# MongoDB Atlas Connection String
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL="your_mongodb_connection_string"
DB_NAME="whatsapp_ai_bot"

# ── Twilio WhatsApp ───────────────────────────────────────────────
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# The Twilio sandbox number — format must include "whatsapp:" prefix
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ── Google Gemini AI ──────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_google_gemini_api_key"
GEMINI_MODEL="gemini-1.5-flash"

# ── Admin Dashboard ───────────────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
JWT_SECRET_KEY="supersecretjwtkey_for_admin_dashboard"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_MINUTES=1440
